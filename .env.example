# ════════════════════════════════════════════════════════════
# Variables de entorno — Muro de Mensajes API
# Copiar a .env y completar con valores reales
# ════════════════════════════════════════════════════════════

# Puerto del servidor (Cloud Run inyecta PORT=8080 automáticamente)
PORT=8080

# URI de conexión a MongoDB Atlas
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/muro_mensajes

# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=cambiar_por_clave_segura_de_32_caracteres_minimo

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=24h

# Rondas de sal para bcrypt (8 = trade-off velocidad/seguridad para estrés)
BCRYPT_SALT_ROUNDS=8
